/**
 * Authentication API Routes
 *
 * Handles user authentication operations:
 * - POST /auth/register - Register new user
 * - POST /auth/login - Login user
 * - POST /auth/logout - Logout user
 * - POST /auth/refresh - Refresh access token
 * - GET /auth/me - Get current user info
 * - POST /auth/verify-email - Verify email address
 * - POST /auth/forgot-password - Request password reset
 * - POST /auth/reset-password - Reset password with token
 */

import { MedusaRequest, MedusaResponse } from '@medusajs/framework/http'
import { z } from 'zod'
import {
  hashPassword,
  verifyPassword,
  validatePassword,
  generateSecureToken
} from '../../auth/password'
import {
  generateAccessToken,
  generateRefreshToken,
  verifyRefreshToken
} from '../../auth/jwt'
import { authenticate, AuthenticatedRequest } from '../../middleware/authenticate'

// ==================== Validation Schemas ====================

const registerSchema = z.object({
  email: z.string().email('Invalid email address'),
  password: z.string().min(8, 'Password must be at least 8 characters'),
  first_name: z.string().min(1, 'First name is required'),
  last_name: z.string().optional(),
  role: z.enum(['buyer', 'seller']).default('buyer')
})

const loginSchema = z.object({
  email: z.string().email('Invalid email address'),
  password: z.string().min(1, 'Password is required')
})

const refreshTokenSchema = z.object({
  refresh_token: z.string().min(1, 'Refresh token is required')
})

const verifyEmailSchema = z.object({
  token: z.string().min(1, 'Verification token is required')
})

const forgotPasswordSchema = z.object({
  email: z.string().email('Invalid email address')
})

const resetPasswordSchema = z.object({
  token: z.string().min(1, 'Reset token is required'),
  password: z.string().min(8, 'Password must be at least 8 characters')
})

// ==================== Route Handlers ====================

/**
 * POST /auth/register
 * Register a new user account
 */
export async function POST(
  req: MedusaRequest,
  res: MedusaResponse
): Promise<void> {
  const action = req.url.split('/').pop()

  switch (action) {
    case 'register':
      return handleRegister(req, res)
    case 'login':
      return handleLogin(req, res)
    case 'logout':
      return handleLogout(req as AuthenticatedRequest, res)
    case 'refresh':
      return handleRefresh(req, res)
    case 'verify-email':
      return handleVerifyEmail(req, res)
    case 'forgot-password':
      return handleForgotPassword(req, res)
    case 'reset-password':
      return handleResetPassword(req, res)
    default:
      res.status(404).json({ message: 'Endpoint not found' })
  }
}

/**
 * GET /auth/me
 * Get current authenticated user information
 */
export async function GET(
  req: MedusaRequest,
  res: MedusaResponse
): Promise<void> {
  // Apply authentication middleware
  authenticate(req as AuthenticatedRequest, res, async () => {
    return handleGetCurrentUser(req as AuthenticatedRequest, res)
  })
}

// ==================== Handler Functions ====================

async function handleRegister(
  req: MedusaRequest,
  res: MedusaResponse
): Promise<void> {
  try {
    // Validate request body
    const validatedData = registerSchema.parse(req.body)

    // Validate password strength
    const passwordValidation = validatePassword(validatedData.password)
    if (!passwordValidation.isValid) {
      res.status(400).json({
        message: 'Password validation failed',
        error: passwordValidation.error
      })
      return
    }

    // TODO: Check if user already exists (will be implemented with User model)
    // For now, we'll simulate user creation

    // Hash password
    const hashedPassword = await hashPassword(validatedData.password)

    // Generate email verification token
    const verificationToken = generateSecureToken(32)

    // TODO: Save user to database
    const mockUserId = `user_${Date.now()}`

    // TODO: Send verification email

    res.status(201).json({
      message: 'User registered successfully',
      data: {
        user_id: mockUserId,
        email: validatedData.email,
        first_name: validatedData.first_name,
        last_name: validatedData.last_name,
        role: validatedData.role,
        email_verified: false
      }
    })
  } catch (error) {
    if (error instanceof z.ZodError) {
      res.status(400).json({
        message: 'Validation failed',
        errors: error.issues
      })
      return
    }

    res.status(500).json({
      message: 'Registration failed',
      error: error instanceof Error ? error.message : 'Unknown error'
    })
  }
}

async function handleLogin(
  req: MedusaRequest,
  res: MedusaResponse
): Promise<void> {
  try {
    // Validate request body
    const { email, password } = loginSchema.parse(req.body)

    // TODO: Fetch user from database
    // For now, we'll use mock data
    const mockUser = {
      user_id: 'user_123',
      email: email,
      password_hash: await hashPassword('SecurePass123!'), // In real app, from DB
      role: 'buyer' as const,
      email_verified: true
    }

    // Verify password
    const isValidPassword = await verifyPassword(password, mockUser.password_hash)
    if (!isValidPassword) {
      res.status(401).json({
        message: 'Invalid credentials',
        error: 'Email or password is incorrect'
      })
      return
    }

    // Check if email is verified
    if (!mockUser.email_verified) {
      res.status(403).json({
        message: 'Email not verified',
        error: 'Please verify your email before logging in'
      })
      return
    }

    // Generate tokens
    const tokenPayload = {
      user_id: mockUser.user_id,
      email: mockUser.email,
      role: mockUser.role
    }

    const accessToken = generateAccessToken(tokenPayload)
    const refreshToken = generateRefreshToken(tokenPayload)

    // TODO: Store refresh token in Redis/database

    res.status(200).json({
      message: 'Login successful',
      data: {
        user: {
          user_id: mockUser.user_id,
          email: mockUser.email,
          role: mockUser.role
        },
        access_token: accessToken,
        refresh_token: refreshToken
      }
    })
  } catch (error) {
    if (error instanceof z.ZodError) {
      res.status(400).json({
        message: 'Validation failed',
        errors: error.issues
      })
      return
    }

    res.status(500).json({
      message: 'Login failed',
      error: error instanceof Error ? error.message : 'Unknown error'
    })
  }
}

async function handleLogout(
  req: AuthenticatedRequest,
  res: MedusaResponse
): Promise<void> {
  try {
    // TODO: Invalidate refresh token (remove from Redis/database)
    // TODO: Add access token to blacklist (if implementing token blacklist)

    res.status(200).json({
      message: 'Logout successful'
    })
  } catch (error) {
    res.status(500).json({
      message: 'Logout failed',
      error: error instanceof Error ? error.message : 'Unknown error'
